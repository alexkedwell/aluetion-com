{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/automation", "destination": "/automation.html" },
    { "source": "/onboarding", "destination": "/onboarding.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/compare", "destination": "/compare.html" },
    { "source": "/roi", "destination": "/roi.html" },
    { "source": "/dentists", "destination": "/dentists.html" },
    { "source": "/salons", "destination": "/salons.html" },
    { "source": "/chiropractors", "destination": "/chiropractors.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/website-builder", "destination": "/website-builder.html" },
    { "source": "/lead-enrichment", "destination": "/lead-enrichment.html" },
    { "source": "/email-verification", "destination": "/email-verification.html" },
    { "source": "/crm-enrichment", "destination": "/crm-enrichment.html" },
    { "source": "/ai-personalization", "destination": "/ai-personalization.html" },
    { "source": "/contact-finder", "destination": "/contact-finder.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://formspree.io https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://formspree.io https://www.google-analytics.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://formspree.io;"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://aluetion.com"
        }
      ]
    }
  ]
}
